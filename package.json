{
  "name": "jitlog",
  "version": "1.0.0",
  "description": "JIT task logger — macOS menubar app",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac"
  },
  "build": {
    "appId": "com.jitlog.app",
    "productName": "JITlog",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "extraResources": []
  },
  "dependencies": {
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  }
}
